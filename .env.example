# ============================================================
# AI Research Agent - Environment Variables Example
# Copy this file to .env and fill in your values
# ============================================================

# Ollama model to use for research and report generation
# Options: llama3.2:3b (default, fast), llama3.1:8b (better quality), mistral, etc.
OLLAMA_MODEL=llama3.2:3b

# SQLAlchemy database connection string
# Default: local SQLite file (no setup needed)
DATABASE_URL=sqlite:///research_agent.db

# Flask server settings (web app only)
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# Directory where generated Markdown reports are saved
REPORTS_DIR=reports
